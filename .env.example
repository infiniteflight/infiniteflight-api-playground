# OAuth clients created at https://infiniteflight.com/account/api-keys or in the Infinite Flight admin dashboard.
# Configure both to show the side-by-side Confidential/Public PKCE sample in the top bar.
IF_CONFIDENTIAL_CLIENT_ID=ifc_your_confidential_client_id
IF_CONFIDENTIAL_CLIENT_SECRET=your_one_time_confidential_client_secret
IF_PUBLIC_CLIENT_ID=ifc_your_public_client_id

# Register this exact redirect URI on both OAuth clients.
APP_BASE_URL=http://localhost:5117
IF_CONFIDENTIAL_REDIRECT_URI=http://localhost:5117/
IF_PUBLIC_REDIRECT_URI=http://localhost:5117/

# For a quick single-client local run, these legacy variables still work:
# IF_OAUTH_CLIENT_TYPE=confidential
# IF_CLIENT_ID=ifc_your_client_id
# IF_CLIENT_SECRET=your_one_time_client_secret
# IF_REDIRECT_URI=http://localhost:5117/

# Local AuthApi OAuth root. Do not include /v2 here; the sample appends /v2/connect/*.
IF_AUTH_BASE=http://localhost:5068
IF_PUBLIC_API_BASE=http://localhost:5069

# offline_access requests a refresh token so the sample can renew access without another login.
IF_SCOPES=openid profile offline_access live:organizations.read live:aircraft.read live:schedules.read

PORT=5117
